# Google OAuth2 Credentials
# Get these from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# Google Workspace IDs
# The ID from your Google Sheet URL: docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here
# The ID from your Google Drive folder URL
GOOGLE_DRIVE_FOLDER=your_google_drive_folder_id_here

# Prompt file paths (relative to project root)
RESEARCH_PROMPTS=prompts/research.md
SCRIPT_PROMPTS=prompts/script.md
VISUAL_PROMPTS=prompts/visuals.md

# Optional: Web search API (Brave Search)
# Get from https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Optional: Reddit API (for Reddit research)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=youtube-mcp/1.0

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Cache settings
CACHE_DIR=cache
CACHE_TTL_HOURS=24

# Google Drive folder names (created automatically under GOOGLE_DRIVE_FOLDER)
DRIVE_RESEARCH_FOLDER=Research
DRIVE_SCRIPTS_FOLDER=Scripts
DRIVE_THUMBNAILS_FOLDER=Thumbnail Ideas
DRIVE_ASSETS_FOLDER=Assets
DRIVE_PUBLISHED_FOLDER=Published
